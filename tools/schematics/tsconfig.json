{
  "extends": "../tsconfig.tools.json",
  "compilerOptions": {
    "outDir": "../../dist/commerce",
    "rootDir": ".",
    "module": "commonjs",
    "target": "es2022",
    "lib": ["es2022"],
    "declaration": true,
    "experimentalDecorators": true,
    "importHelpers": false,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "**/*.ts",
  ],
  "exclude": [
    "**/*.spec.ts",
    "**/files/**/*.ts",
    "node_modules"
  ]
}