{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/spec",
		"module": "commonjs",
		"moduleResolution": "node",
    "types": [
      "jasmine",
      "node"
    ],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": [
    "**/*.spec.ts",
    "**/*.d.ts"
  ]
}